# Get your free Gemini API key from https://aistudio.google.com/apikey
# NOTE: In this app the API key is entered via the UI (Advanced Settings on homepage)
#       and stored in localStorage — the server-side key below is optional/unused locally.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Supabase (only needed for auth + save sessions feature)
# Create a free project at https://supabase.com
# Then copy the URL and anon key from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
